Problem Statement - Minimum Depth of Binary Tree (Leetcode 111)
//Code
class Solution {
public:
    int minDepth(TreeNode* root) {
        if(root == nullptr){
            return 0;
        }
        int lh = minDepth(root->left);
        int rh = minDepth(root->right);

        if(lh == 0 || rh == 0){
            return lh + rh + 1;
        }
        return min(lh, rh) + 1;
    }
};

Problem Statement - Smae Tree (Leetcode 100)
//Code
class Solution {
public:
    bool isSameTree(TreeNode* p, TreeNode* q) {
        if(p == nullptr && q == nullptr){
            return true;
        }
        if(p == nullptr || q == nullptr){
            return false;
        }
        if(p->val != q->val){
            return false;
        }
        return isSameTree(p->left,q->left) && isSameTree(p->right, q->right);
    }
};

Problem Statement - Balanced Binary Tree (Leetcode 110)
//Code
class Solution {
public:
    int traversal(TreeNode* root){
        if(root == nullptr){
            return 0;
        }
        int lh = traversal(root->left);
        if(lh == -1){
            return -1;
        }
        int rh = traversal(root->right);
        if(rh == -1){
            return -1;
        }

        if(abs(lh-rh) > 1){
            return -1;
        }
        return max(lh, rh) + 1;
    }
    bool isBalanced(TreeNode* root) {
        return traversal(root) != -1;
    }
};

Problem Statement - Diameter of Binary Tree (Leetcode 543)
//Code
class Solution {
public:
    int traversal(TreeNode* root){
        if(root == nullptr){
            return 0;
        }
        int lh = traversal(root->left);
        int rh = traversal(root->right);

        int max_depth = max(lh, rh) + 1;
        return max_depth;
    }
    int diameterOfBinaryTree(TreeNode* root) {
        if(root == nullptr){
            return 0;
        }
        int dia1 = diameterOfBinaryTree(root->left);
        int dia2 = diameterOfBinaryTree(root->right);
        int dia3 = traversal(root->left) + traversal(root->right);
        return max(dia1, max(dia2, dia3));
        
    }
};
