Problem Statment - Majority Elements (Leetcode 169)
//Code (By sort libraies)
class Solution {
public:
    int majorityElement(vector<int>& nums) {
        sort(nums.begin(), nums.end());
        int n = nums.size();
        return nums[n/2];
    }
};
