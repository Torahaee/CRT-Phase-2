Problem Statement - Product of Array Except Self
//Code
class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();
        vector<int> ans(n);
        for(int i =0; i<nums.size(); i++){
            int product = 1;
            for(int j=0; j<nums.size(); j++){
                if(i == j){
                    continue;
                }
                product = product*nums[j];
            }
            ans[i] = product;
        }
        return ans;
    }
};
