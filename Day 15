Problem Statement - House Robber (Leetcode 198)
//Code
class Solution {
public:
    int robFrom(vector<int>& nums, int index){
        //base condition
        if(index >= nums.size()){
            return 0;
        }
        
        //logic
        int rob = nums[index] + robFrom(nums, index + 2);
        int notRob = robFrom(nums, index +1);
        return max(rob, notRob);
    }
    int rob(vector<int>& nums) {
        return robFrom(nums, 0);
    }
};
