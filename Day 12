Problem Statement - DFS in Graph (GFG)
//Code
class Solution {
  public:
  
    void dfsHelper(vector<vector<int>>& adj, vector<bool>& visited, vector<int>& ans, int node){
        visited[node] = true;
        ans.push_back(node);
        
        for(int adjacentNode : adj[node]){
            if(!visited[adjacentNode]){
                dfsHelper(adj, visited, ans, adjacentNode);
            }
        }
    }
    vector<int> dfs(vector<vector<int>>& adj) {
        // Code here
        int n = adj.size();
        vector<bool> visited(n, false);
        vector<int> ans;
        
        dfsHelper(adj, visited, ans, 0);
        
        return ans;
    }
};

Problem Statement - BFS in Graph (GFG)
//Code
class Solution {
  public:
    vector<int> bfs(vector<vector<int>> &adj) {
        // code here
        int n = adj.size();
        vector<bool> visited(n, false);
        vector<int> ans;
        queue<int> q;
        
        q.push(0);
        visited[0] = true;
        
        while(!q.empty()){
            int node = q.front();
            q.pop();
            
            ans.push_back(node);
            for(int adjacentNode : adj[node]){
                if(!visited[adjacentNode]){
                    visited[adjacentNode] = true;
                    q.push(adjacentNode);
                }
            }
        }
        return ans;
    }
};

